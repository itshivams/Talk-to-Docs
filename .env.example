ENV=development
APP_NAME=talk-to-docs

# Shared
JWT_SECRET=replace-with-a-long-random-secret
ALLOWED_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Postgres
POSTGRES_DB=talk_to_docs
POSTGRES_USER=talk
POSTGRES_PASSWORD=talk
DATABASE_URL=postgres://talk:talk@localhost:5432/talk_to_docs?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_ADDR=localhost:6379
INGEST_QUEUE=ingest_jobs

# RAG
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=talk_to_docs_chunks
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:0.5b

# Scraping and rate limits
SCRAPE_TIMEOUT_SECONDS=12
MAX_PAGE_BYTES=2000000
MIN_TEXT_CHARS=500
RATE_LIMIT_PER_MINUTE=120
